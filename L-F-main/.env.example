# Lost & Found Platform - Environment Configuration Template

# Copy this file to .env and fill in your own values
# IMPORTANT: Never commit .env file to version control!

# Server Configuration
PORT=3000
NODE_ENV=development

# Database
# Default: data/lost-found.sqlite (created automatically)
DB_PATH=data/lost-found.sqlite

# Security
JWT_SECRET=your-very-secret-key-change-this-in-production
JWT_EXPIRY=7d

# Logging
DEBUG=true

# Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# CORS
CORS_ORIGIN=*

# Email Configuration (for future password reset feature)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Application URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# Optional: Sentry Error Tracking
SENTRY_DSN=

# Optional: Analytics
ANALYTICS_TOKEN=
